APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080

# PostgreSQL Connection
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fenturun2026
DB_USERNAME=scanner_service
DB_PASSWORD=scanner_password
DB_SSLMODE=disable

DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_STATEMENT_TIMEOUT=3s

SESSION_SECRET=change-me-to-at-least-32-bytes-secret
SESSION_IDLE_TIMEOUT=30m
SESSION_ABSOLUTE_TIMEOUT=8h

ALLOWED_SCANNER_ROLES=admin,super_admin
ALLOWED_SCANNER_PERMISSIONS=scanner.access
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:5174

APP_TIMEZONE=Asia/Makassar
LOG_LEVEL=info
