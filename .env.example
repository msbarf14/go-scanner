APP_ENV=development
HTTP_ADDR=:8080
PUBLIC_BASE_URL=http://localhost:8080

# Frontend build-time assets. In Coolify these can be Build Variables only.
VITE_ASSET_BASE_URL=https://r2.fenturun2026.com/assets
VITE_ASSET_VERSION=11

# PostgreSQL Connection
DB_CONNECTION=pgsql
DB_HOST=127.0.0.1
DB_PORT=5432
DB_DATABASE=fenturun2026
DB_USERNAME=scanner_service
DB_PASSWORD=scanner_password
DB_SSLMODE=disable

DB_MAX_CONNECTIONS=10
DB_MIN_CONNECTIONS=1
DB_STATEMENT_TIMEOUT=3s

# Required in production. Generate with: openssl rand -base64 32
SESSION_SECRET=change-me-to-at-least-32-bytes-secret
SESSION_IDLE_TIMEOUT=30m
SESSION_ABSOLUTE_TIMEOUT=8h

# Required. Use a valid users.id ULID for race-pack pickup attribution.
DEFAULT_OPERATOR_ID=01JXXXXXXXXXXXXXXXXXXXXXXX

ALLOWED_SCANNER_ROLES=admin,super_admin
ALLOWED_SCANNER_PERMISSIONS=scanner.access

APP_TIMEZONE=Asia/Makassar
LOG_LEVEL=info
TRUSTED_PROXY_CIDRS=
